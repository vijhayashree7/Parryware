# ─── AI (OpenRouter — free models available) ─────────────────────
# Sign up FREE at https://openrouter.ai and get your API key
# Model: minimax/minimax-m2.5:free (completely free)
OPENROUTER_API_KEY=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

# ─── WhatsApp Business Cloud API ─────────────────────────────────
# From Meta Developer Dashboard → WhatsApp → Getting Started
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_BUSINESS_NUMBER=+91XXXXXXXXXX

# ─── Webhook ─────────────────────────────────────────────────────
# You create this — any random secret string (remember it for Meta dashboard)
WEBHOOK_VERIFY_TOKEN=abirami_parryware_secret_2024

# ─── Database ────────────────────────────────────────────────────
# Free MongoDB Atlas: https://www.mongodb.com/atlas/database
# Leave empty to run without DB (conversations won't persist on server)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/parryware_chatbot

# ─── Server ──────────────────────────────────────────────────────
PORT=3001

# ─── CORS — update with your production frontend URL
FRONTEND_URL=http://localhost:5173
