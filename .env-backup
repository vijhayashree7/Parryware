# Backend API URL — leave empty to use Vite proxy (recommended for dev)
# In production, set this to your deployed backend URL e.g. https://your-server.railway.app
VITE_API_URL=

# WhatsApp Business Number for the "Open in WhatsApp" button (include country code)
# Example: +919876543210
VITE_WA_BUSINESS_NUMBER=+91XXXXXXXXXX
